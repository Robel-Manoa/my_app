{
  "name": "internal-portal-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Internal Company Portal backend using hexagonal architecture",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --runInBand --coverage",
    "test:coverage": "jest --coverage --runInBand",
    "sonar": "npm run test:coverage && sonar-scanner",
    "seed": "ts-node src/infrastructure/database/seed.ts",
    "seed:reset": "ts-node src/infrastructure/database/seed.ts --reset"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "uuid": "^9.0.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.4.2",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
