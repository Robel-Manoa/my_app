# SonarQube Configuration
# Copy this file to .env and fill in your values

# SonarCloud Configuration (recommended)
SONAR_HOST_URL=https://sonarcloud.io
SONAR_LOGIN=SONAR_TOKEN
SONAR_PASSWORD=


# Project Configuration (optional - auto-detected from sonar-project.properties)
# SONAR_PROJECT_KEY=Robel-Manoa_my-app
# SONAR_ORGANIZATION=robel-manoa

# Logging Configuration
SONAR_VERBOSE=false
# SONAR_DEBUG=true

# Additional SonarQube Parameters (optional)
# SONAR_SCANNER_PARAMS="-Dsonar.qualitygate.wait=true"
